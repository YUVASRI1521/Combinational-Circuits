module tb_ripple_carry_add_4;

reg [3:0] a, b;
reg cin;
wire [3:0] s;
wire cout;

integer i, j;

ripple_carry_add_4 dut(
  .a(a),
  .b(b),
  .cin(cin),
  .s(s),
  .cout(cout)
);

initial begin

  $monitor("Time=%0t | a=%b | b=%b | cin=%b | s=%b | cout=%b",
           $time, a, b, cin, s, cout);

  cin = 0;

  for(i = 0; i < 16; i = i + 1)
    for(j = 0; j < 16; j = j + 1) begin
      a = i;
      b = j;
      #5;
    end

  $finish;

end

endmodule
